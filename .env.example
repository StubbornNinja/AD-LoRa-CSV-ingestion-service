# ChirpStack REST API
CHIRPSTACK_API_URL=http://chirpstack:8080/api
CHIRPSTACK_API_TOKEN=replace-with-chirpstack-api-token

# API auth token (NGINX injects this as Bearer header on the frontend VM)
INGEST_API_TOKEN=replace-with-random-ingest-token

# ChirpStack application UUID target for imported devices
APPLICATION_ID=replace-with-chirpstack-application-uuid

# Device profile UUID to apply to imported devices
DEVICE_PROFILE_ID=replace-with-device-profile-uuid

# Legacy compatibility variable (optional if DEVICE_PROFILE_ID is set)
LW010_PROFILE_ID=

# Base data directory (upload dir and db path default relative to this)
INGEST_DATA_DIR=/opt/chirpstack-ingest

# Override individual paths (optional — defaults to {INGEST_DATA_DIR}/uploads and {INGEST_DATA_DIR}/data/jobs.db)
UPLOAD_DIR=
DB_PATH=

# Upload safety limit (10 MiB default)
MAX_UPLOAD_BYTES=10485760
